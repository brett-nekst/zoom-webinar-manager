# Zoom Server-to-Server OAuth App credentials
# Create at: https://marketplace.zoom.us -> Develop -> Build App -> Server-to-Server OAuth
ZOOM_ACCOUNT_ID=your_account_id_here
ZOOM_CLIENT_ID=your_client_id_here
ZOOM_CLIENT_SECRET=your_client_secret_here

# Your Zoom account email address (ensures meetings are created under your user)
ZOOM_USER_ID=you@yourdomain.com

# Cron job security secret (any random string you choose)
# Add this to Vercel Environment Variables too
# Vercel automatically uses this to secure cron routes
CRON_SECRET=any_random_secret_string_here

# HubSpot - for registration page
# Portal ID from HubSpot Settings > Account Setup
HUBSPOT_PORTAL_ID=your_portal_id_here
# Form ID from the HubSpot form URL or embed code
HUBSPOT_FORM_ID=your_form_id_here
# Private App token with crm.objects.contacts.read + crm.objects.contacts.write scopes
HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-your_token_here

# Google Sheets - master registration log
# Service account email (reuse an existing service account, or create one)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Service account private key (PEM). Keep the literal \n escapes on one line.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_key_here\n-----END PRIVATE KEY-----\n"
# Master registration sheet ID (defaults to the shared sheet if omitted)
REGISTRATION_SHEET_ID=1pt8LuAaMdLhpnpxVPod04QWaIEYiVKG2bkzf-E1VZM0

# Email added as alternative host on every webinar (must be a licensed user
# on the same Zoom account). Defaults to adrian@nekst.com if unset.
ALTERNATIVE_HOST_EMAIL=adrian@nekst.com
